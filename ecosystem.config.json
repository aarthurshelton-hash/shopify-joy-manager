      "log_file": "/tmp/pm2-system-monitor.log",
      "error_file": "/tmp/pm2-system-monitor-error.log",
      "out_file": "/tmp/pm2-system-monitor-out.log",
      "merge_logs": true,
      "max_memory_restart": "200M",
      "restart_delay": 10000
