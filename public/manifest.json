{
  "name": "En Pensent - Chess Art Prints",
  "short_name": "En Pensent",
  "description": "Transform chess games into stunning generative art. Scan, create, and collect unique visualizations.",
  "theme_color": "#d4af37",
  "background_color": "#0f1419",
  "display": "standalone",
  "orientation": "any",
  "scope": "/",
  "start_url": "/",
  "id": "/",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "icons": [
    {
      "src": "/favicon.png",
      "sizes": "64x64",
      "type": "image/png"
    },
    {
      "src": "/pwa-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "categories": ["games", "lifestyle", "entertainment", "art"],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Create Vision",
      "short_name": "Create",
      "description": "Design your own chess art",
      "url": "/creative-mode",
      "icons": [{ "src": "/favicon.png", "sizes": "64x64" }]
    },
    {
      "name": "My Visions",
      "short_name": "Gallery",
      "description": "View your saved visions",
      "url": "/my-vision",
      "icons": [{ "src": "/favicon.png", "sizes": "64x64" }]
    },
    {
      "name": "Play Chess",
      "short_name": "Play",
      "description": "Play with live visualization",
      "url": "/play",
      "icons": [{ "src": "/favicon.png", "sizes": "64x64" }]
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "text": "pgn"
    }
  },
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "prefer_related_applications": false
}
